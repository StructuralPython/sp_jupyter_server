# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in values for local testing.
#
# On bunny.net Magic Containers these are set via the dashboard form
# (defined by the BunnyVar_ comment lines in docker-compose.yml).
# ─────────────────────────────────────────────────────────────────────────────

# Email address used to log in to the Authelia portal
AUTH_EMAIL=you@example.com

# Initial login password for Authelia (will be bcrypt-hashed at first boot)
AUTH_PASSWORD=changeme123

# Space-separated list of Python packages to install in the venv.
# The kernel is re-registered each time the container starts so changes
# take effect on the next restart.
PYTHON_PACKAGES=structural_starterkit
