FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# 1. Install system tools
RUN sed -i 's|http://|https://|g' /etc/apt/sources.list.d/ubuntu.sources
RUN apt-get -o "Acquire::https::Verify-Peer=false" update && \
    apt-get -o "Acquire::https::Verify-Peer=false" install -y --no-install-recommends \
curl \
    wget \
    git \
    nano \
    graphviz \
    sudo \
    ca-certificates \
    build-essential \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# 2. Setup user
RUN useradd -m -s /bin/bash devuser && \
    echo "devuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 3. Install Quarto
RUN curl -LO https://quarto.org/download/latest/quarto-linux-amd64.deb && \
    dpkg -i quarto-linux-amd64.deb && \
    rm quarto-linux-amd64.deb

USER devuser
WORKDIR /home/devuser

# 4. TinyTeX
RUN quarto install tinytex --no-prompt

# 5. uv & Python 3.13
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
ENV PATH="/home/devuser/.local/bin:${PATH}"

RUN uv venv .venv --python 3.13 && \
    . .venv/bin/activate && \
    uv pip install jupyterlab ipykernel structural_starterkit && \
    python -m ipykernel install --user --name sp --display-name "Python 3 (Structural Python)"

EXPOSE 8888

# Use --ServerApp flags for modern JupyterLab proxy compatibility
CMD ["/home/devuser/.venv/bin/jupyter", "lab", \
     "--ip=0.0.0.0", \
     "--no-browser", \
     "--NotebookApp.token=''", \
     "--NotebookApp.password=''", \
     "--ServerApp.allow_origin='*'", \
     "--ServerApp.disable_check_xsrf=True"]